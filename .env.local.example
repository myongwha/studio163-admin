# Supabase 接続情報（管理画面は必須）
# 公開サイト(studio163) と同じ Supabase プロジェクトを指定します。
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# 公開アプリ(studio163)のURL。「アプリケーションへ」リンク先に使用。
# 未設定時は http://localhost:7778 にフォールバックします。
NEXT_PUBLIC_APP_URL=https://studio163.vercel.app
